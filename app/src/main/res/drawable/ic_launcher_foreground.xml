<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Glowing Clock-like Circular Arc -->
    <path
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:pathData="M 38,34 A 23,23 0 1,1 72,74">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="38"
                android:startY="34"
                android:endX="72"
                android:endY="74"
                android:type="linear">
                <item android:offset="0.0" android:color="#06B6D4" /> <!-- Neon Cyan-Blue -->
                <item android:offset="0.5" android:color="#3B82F6" /> <!-- Electric Blue -->
                <item android:offset="1.0" android:color="#A855F7" /> <!-- Neon Purple -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bold Centered White Checkmark -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M 46,51 L 53,58 L 66,42" />

    <!-- Checklist Card Group -->
    <group
        android:translateX="18"
        android:translateY="35">
        <!-- Card Background -->
        <path
            android:fillColor="#10141F"
            android:strokeColor="#2C374E"
            android:strokeWidth="1"
            android:pathData="M 2,2 L 18,2 A 2,2 0 0,1 20,4 L 20,24 A 2,2 0 0,1 18,26 L 2,26 A 2,2 0 0,1 0,24 L 0,4 A 2,2 0 0,1 2,2 Z" />
        <!-- Blue Checkbox 1 -->
        <path
            android:fillColor="#3B82F6"
            android:pathData="M 3,5 L 7,5 A 1,1 0 0,1 8,6 L 8,10 A 1,1 0 0,1 7,11 L 3,11 A 1,1 0 0,1 2,10 L 2,6 A 1,1 0 0,1 3,5 Z" />
        <!-- Tiny checkmark inside blue checkbox 1 -->
        <path
            android:strokeColor="#FFFFFF"
            android:strokeWidth="0.8"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M 4,8 L 5.2,9.2 L 6.8,6.8" />
        <!-- Line 1 -->
        <path
            android:strokeColor="#94A3B8"
            android:strokeWidth="1.2"
            android:strokeLineCap="round"
            android:pathData="M 11,8 L 17,8" />
            
        <!-- Checkbox 2 (Outline) -->
        <path
            android:strokeColor="#475569"
            android:strokeWidth="0.8"
            android:pathData="M 3,11 L 7,11 A 1,1 0 0,1 8,12 L 8,16 A 1,1 0 0,1 7,17 L 3,17 A 1,1 0 0,1 2,16 L 2,12 A 1,1 0 0,1 3,11 Z" />
        <!-- Line 2 -->
        <path
            android:strokeColor="#475569"
            android:strokeWidth="1.2"
            android:strokeLineCap="round"
            android:pathData="M 11,14 L 17,14" />

        <!-- Checkbox 3 (Outline) -->
        <path
            android:strokeColor="#475569"
            android:strokeWidth="0.8"
            android:pathData="M 3,17 L 7,17 A 1,1 0 0,1 8,18 L 8,22 A 1,1 0 0,1 7,23 L 3,23 A 1,1 0 0,1 2,22 L 2,18 A 1,1 0 0,1 3,17 Z" />
        <!-- Line 3 -->
        <path
            android:strokeColor="#475569"
            android:strokeWidth="1.2"
            android:strokeLineCap="round"
            android:pathData="M 11,20 L 17,20" />
    </group>

    <!-- Glowing Purple Notification Bell -->
    <group
        android:translateX="67"
        android:translateY="62"
        android:scaleX="0.85"
        android:scaleY="0.85">
        <path
            android:fillColor="#A855F7"
            android:pathData="M12,22c1.1,0,2,-0.9,2,-2h-4c0,1.1,0.9,2,2,2zm6,-6v-5c0,-3.07,-1.63,-5.64,-4.5,-6.32V4c0,-0.83,-0.67,-1.5,-1.5,-1.5s-1.5,0.67,-1.5,1.5v0.68C7.64,5.36,6,7.92,6,11v5l-2,2v1h16v-1l-2,-2z" />
    </group>

</vector>
